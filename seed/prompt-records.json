[
  {
    "_id": "prompt.generate-note-article",
    "_type": "prompt",
    "title": "note記事を生成する",
    "targetPlatform": "note",
    "outputType": "note-article",
    "localFilePath": "prompts/generate-note-article.md",
    "requiredInputFields": [
      "title",
      "summary",
      "coreThesis",
      "audience",
      "audiencePain",
      "claims",
      "evidence",
      "examples",
      "objections",
      "tone",
      "platformAngles"
    ],
    "humanReviewChecklist": [
      "coreThesisが変わっていないか",
      "元レコードにない主張を足していないか",
      "note記事として読める自然な流れになっているか",
      "公開前に確認すべき根拠や表現はあるか",
      "保存先はoutputs/note/でよいか"
    ],
    "outputPathPattern": "outputs/note/YYYY-MM-DD--source-slug--note.md",
    "version": "0.1.0",
    "status": "active",
    "notes": "Markdownファイルを正本として扱う。promptBodyはMVPでは複製しない。"
  },
